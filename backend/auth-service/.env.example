# ================================================================
# REPLACE THESE WITH YOUR REAL VALUES
# ================================================================

# Supabase — Settings > Database > Transaction pooler URI (port 6543)
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Upstash Redis — Connect > UPSTASH_REDIS_URL
REDIS_URL=rediss://default:YOUR_PASSWORD@xxx.upstash.io:6379

# AfricasTalking — Settings > API Key
AT_API_KEY=YOUR_AT_API_KEY
AT_USERNAME=YOUR_AT_USERNAME

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_SUPER_SECRET_KEY_REPLACE_THIS

PORT=3001
NODE_ENV=development
